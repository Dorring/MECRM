{
  "uid": "chaos-reliability",
  "title": "Chaos & Reliability",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Circuit Breaker State (0=CLOSED, 1=OPEN, 2=HALF_OPEN)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(circuit_breaker_state) by (breaker, dependency, tenant_id)",
          "legendFormat": "{{breaker}} {{dependency}} {{tenant_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Retry Attempts / sec (storm detection)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(retry_attempts_total[5m])) by (operation, dependency)",
          "legendFormat": "{{operation}} {{dependency}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Retry Failures / sec",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(retry_failures_total[5m])) by (operation, dependency)",
          "legendFormat": "{{operation}} {{dependency}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Consumer Lag",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(consumer_lag) by (group_id, topic, partition)",
          "legendFormat": "{{group_id}} {{topic}} p{{partition}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Replay Failures / sec",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(replay_failures[5m])) by (component, error_type)",
          "legendFormat": "{{component}} {{error_type}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Recovery Time (p95 seconds)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(recovery_time_seconds_bucket[10m])) by (le, breaker, dependency))",
          "legendFormat": "{{breaker}} {{dependency}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 }
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}

