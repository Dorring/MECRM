# Environment Configuration
# Copy this file to .env and update the values
#
# SECURITY NOTICE: Variables marked [REQUIRED IN PRODUCTION] MUST be set to
# strong, unique values before deploying. The Gateway refuses to start in
# production (NODE_ENV=production) when JWT_SECRET is missing or insecure.
# Never commit real secrets; keep .env out of version control.

# ===================
# General
# ==================
NODE_ENV=development
LOG_LEVEL=debug

# ===================
# Database
# ===================
# [REQUIRED IN PRODUCTION] Use a strong password; rotate regularly.
# Compose DERIVES the gateway/agents/migrate DATABASE_URL from POSTGRES_PASSWORD
# (see docker-compose.yml) so they can never drift. Keep POSTGRES_PASSWORD in
# sync with any standalone DATABASE_URL you set below for local non-compose dev.
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=enterprise_crm
# Runtime application role created by 02-rls-policies.sql. Keep this separate
# from the migration owner password; production deployments must rotate it.
CRM_APP_PASSWORD=crm_password
# Local non-compose dev only. In Compose this is overridden by the derived URL.
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/enterprise_crm

# ===================
# Redis
# ===================
# [REQUIRED IN PRODUCTION] Point at a hardened Redis instance. Used for the
# JWT token-revocation blacklist: if Redis is unreachable the Gateway rejects
# tokens (fail closed) unless AUTH_ALLOW_OPENREDIS_FALLBACK=1 (dev/test only,
# never in production — accepts revoked tokens during outages).
REDIS_URL=redis://redis:6379

# ===================
# Kafka
# ===================
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=enterprise-crm
# Topic initialization (ADR-001). Dev single-node Kafka requires replication=1.
KAFKA_REPLICATION_FACTOR=1
KAFKA_DEFAULT_RETENTION_MS=604800000
KAFKA_AUDIT_RETENTION_MS=2592000000
KAFKA_DLQ_RETENTION_MS=1209600000
KAFKA_LEADER_TIMEOUT=120
KAFKA_LEADER_INTERVAL=2

# ===================
# Authentication (Keycloak)
# ===================
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=enterprise-crm
KEYCLOAK_CLIENT_ID=crm-api
# [REQUIRED IN PRODUCTION] Keycloak client secret.
KEYCLOAK_CLIENT_SECRET=change-me-in-production
# [REQUIRED IN PRODUCTION] Keycloak admin. Compose uses these (no hardcoded
# admin/admin). Dev defaults below; override in .env for any non-local env.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ===================
# JWT
# ===================
# [REQUIRED IN PRODUCTION] MUST be set to a strong random value of at least 32
# bytes (e.g. `openssl rand -base64 48`). The Gateway fails to start in
# production if JWT_SECRET is missing, shorter than 32 bytes, or matches a known
# insecure default. In development an insecure fallback is permitted with a
# warning. Rotate by rolling out a new secret and invalidating outstanding tokens.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
# Dev/test only: when "1", trust the JWT signature if Redis is down (insecure).
AUTH_ALLOW_OPENREDIS_FALLBACK=

# ===================
# OPA (Open Policy Agent)
# ===================
OPA_URL=http://opa:8181

# ===================
# AI/LLM (Ollama)
# ===================
# Optional local inference only. The Ollama container belongs to the
# `local-llm` Compose profile and is not started by default.
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# ===================
# Vector Store (Weaviate)
# ===================
WEAVIATE_URL=http://weaviate:8080

# ===================
# Frontend
# ===================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ===================
# Services Ports
# ===================
FRONTEND_PORT=3000
GATEWAY_PORT=4000
LEADS_SERVICE_PORT=5001
DEALS_SERVICE_PORT=5002
TICKETS_SERVICE_PORT=5003
CUSTOMERS_SERVICE_PORT=5004
AGENTS_PORT=5010

# ===================
# Observability
# ===================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# [REQUIRED IN PRODUCTION] Grafana admin. Compose uses this (no hardcoded admin).
GRAFANA_ADMIN_PASSWORD=admin
